# ============================================================
#  PlayPlanner — Environment Variables
#  HOW TO USE:
#    1. Make a copy of this file and rename it to ".env"
#    2. Fill in your real values where you see placeholder text
#    3. NEVER share or commit ".env" — it contains secrets
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# Where to find these:
#   Go to supabase.com → open your project → Settings → API
# ------------------------------------------------------------

# Your project URL (looks like: https://xxxxxxxxxxxx.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# "anon" public key — this is safe to use in the app (the database
# Row Level Security rules prevent users seeing each other's data)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------
# GOOGLE MAPS
# Where to find these:
#   Go to console.cloud.google.com → APIs & Services → Credentials
#   Enable: Maps SDK for Android, Maps SDK for iOS, Places API
# ------------------------------------------------------------

# Android key (used at build time via EAS — see app.json)
GOOGLE_MAPS_API_KEY_ANDROID=your-android-maps-key-here

# iOS key
GOOGLE_MAPS_API_KEY_IOS=your-ios-maps-key-here

# ------------------------------------------------------------
# STRIPE
# Where to find these:
#   Go to dashboard.stripe.com → Developers → API keys
#   Use "pk_test_" / "sk_test_" keys while building & testing
#   Switch to "pk_live_" / "sk_live_" only when going live
# ------------------------------------------------------------

# Publishable key — used inside the app (safe to expose)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Secret key — ONLY for your backend / Supabase Edge Functions
# NEVER put this in the app or prefix it with EXPO_PUBLIC_
STRIPE_SECRET_KEY=sk_test_your-key-here

# Webhook signing secret — verifies that events really came from Stripe
# Find it in: Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret-here

# Stripe Price IDs — create these in Stripe dashboard → Products
# Each plan needs its own Price ID (looks like: price_1Abc123...)
EXPO_PUBLIC_STRIPE_USER_PREMIUM_MONTHLY=price_your-user-premium-monthly-id
EXPO_PUBLIC_STRIPE_USER_PREMIUM_ANNUAL=price_your-user-premium-annual-id
EXPO_PUBLIC_STRIPE_BUSINESS_BASIC=price_your-business-basic-id
EXPO_PUBLIC_STRIPE_BUSINESS_PRO=price_your-business-pro-id

# ------------------------------------------------------------
# EXPO / EAS (Expo Application Services)
# Where to find this:
#   Go to expo.dev → your project → Settings → copy the Project ID
# ------------------------------------------------------------

EAS_PROJECT_ID=4cbd1146-859f-44b6-80dd-52ed7d61800a
