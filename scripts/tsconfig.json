{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./.build",
    "rootDir": "..",
    "baseUrl": "..",
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "../types/enrichment.ts"
  ],
  "exclude": [
    "node_modules",
    ".build"
  ]
}
