{
  "expo": {
    "name": "Play Planner",
    "slug": "play-planner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "playplanner",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4ECDC4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.playplanner.app",
      "buildNumber": "1",
      "config": {
        "googleMapsApiKey": "$(GOOGLE_MAPS_API_KEY_IOS)"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Play Planner uses your location to show nearby child-friendly venues. Location is only used while you are browsing the map.",
        "NSLocationAlwaysUsageDescription": "Play Planner uses your location to show nearby child-friendly venues.",
        "NSCameraUsageDescription": "Play Planner needs camera access to let you upload photos of venues.",
        "NSPhotoLibraryUsageDescription": "Play Planner needs photo library access to let you upload venue photos.",
        "NSPhotoLibraryAddUsageDescription": "Play Planner saves venue photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4ECDC4"
      },
      "package": "com.playplanner.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "$(GOOGLE_MAPS_API_KEY_ANDROID)"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Play Planner uses your location to show nearby venues. Location is only accessed while you are using the map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Play Planner needs photo access to upload venue photos.",
          "cameraPermission": "Play Planner needs camera access to take venue photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#4ECDC4"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4cbd1146-859f-44b6-80dd-52ed7d61800a"
      },
      "privacyPolicyUrl": "https://lennons-space.github.io/playplanner/privacy.html",
      "supportUrl": "https://lennons-space.github.io/playplanner"
    },
    "owner": "playplanner"
  }
}
